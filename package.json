{
  "name": "zero",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "if [ -d .git ]; then lefthook install; fi",
    "dev": "pnpm --filter @zero/web dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . && markdownlint-cli2",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix",
    "typecheck": "pnpm --filter @zero/core typecheck",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @zero/web db:generate",
    "db:migrate": "pnpm --filter @zero/web db:migrate",
    "db:push": "pnpm --filter @zero/web db:push",
    "db:studio": "pnpm --filter @zero/web db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/next": "^2.0.6",
    "@tsconfig/node24": "^24.0.4",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^24.12.4",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
